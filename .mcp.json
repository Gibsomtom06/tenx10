{
  "mcpServers": {
    "supabase": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--access-token",
        "${SUPABASE_ACCESS_TOKEN}",
        "--project-ref",
        "ocscxqaythiuidkwjuvg"
      ],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "${SUPABASE_ACCESS_TOKEN}"
      }
    },
    "gmail": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "gmail-mcp@latest"
      ]
    },
    "google-calendar": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "google-calendar-mcp@latest"
      ]
    },
    "google-drive": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "google-drive-mcp@latest"
      ]
    },
    "meta-ads": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "meta-ads-mcp@latest"
      ]
    }
  }
}
